    rfp:dimension "stage-1-req" ;
    rdfs:label "Upgrades with potential loss-of-funds not protected with Exit Window >= 7 days OR sufficient Security Council — unfixed" .
aave:v3-eth-req-s1-2 a rfp:Finding ; rfp:statedBy feed:defiscan ; rfp:about aave:v3-ethereum ;
    rfp:dimension "stage-1-req" ;
    rdfs:label "Dependency with a High centralization score without mitigation — unfixed" .
aave:v3-eth-req-s1-3 a rfp:Finding ; rfp:statedBy feed:defiscan ; rfp:about aave:v3-ethereum ;
    rfp:dimension "stage-1-req" ;
    rdfs:label "Frontend backups or self-hosting option exists — fixed" .
aave:v3-eth-req-s2-1 a rfp:Finding ; rfp:statedBy feed:defiscan ; rfp:about aave:v3-ethereum ;
    rfp:dimension "stage-2-req" ;
    rdfs:label "Loss-of-funds upgrades not protected with onchain governance AND Exit Window >= 30 days — unfixed" .
aave:v3-eth-req-s2-2 a rfp:Finding ; rfp:statedBy feed:defiscan ; rfp:about aave:v3-ethereum ;
    rfp:dimension "stage-2-req" ;
