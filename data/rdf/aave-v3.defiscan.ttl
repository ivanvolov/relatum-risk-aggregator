    rfp:statedBy feed:defiscan ; rfp:about aave:v3-ethereum ;
    rdfs:label "Risk Council multisig: GhoDirectMinter caps; reserve-parameter stewards" ;
    rfp:dimension "permission" .
aave:v3-eth-perm-aave-governance a rfp:Permission ;
    rfp:statedBy feed:defiscan ; rfp:about aave:v3-ethereum ;
    rdfs:label "Aave Governance: full upgradeability over Pool, aTokens, debt tokens, GhoStabilityModule, GhoDirectMinter" ;
    rfp:dimension "permission" .
aave:v3-eth-perm-governance-guardian a rfp:Permission ;
    rfp:statedBy feed:defiscan ; rfp:about aave:v3-ethereum ;
    rdfs:label "Aave Governance v3 Guardian multisig: can cancel proposals (Security Council compliant)" ;
    rfp:dimension "permission" .

# Dependencies
aave:v3-eth-dep-chainlink a rfp:Dependency ;
    rfp:statedBy feed:defiscan ; rfp:about aave:v3-ethereum ;
    rdfs:label "Chainlink oracle feeds — High centralization, unmitigated (no functional fallback)" ;
    rfp:dimension "oracle-dependency" .
aave:v3-eth-dep-adi a rfp:Dependency ;
    rfp:statedBy feed:defiscan ; rfp:about aave:v3-ethereum ;
    rdfs:label "a.DI cross-chain messaging (2/3 bridge threshold) for governance votes held on Polygon" ;
    rfp:dimension "cross-chain-dependency" .
aave:v3-eth-dep-usdc a rfp:Dependency ;
    rfp:statedBy feed:defiscan ; rfp:about aave:v3-ethereum ;
    rdfs:label "GHO mintable 1:1 against centralized USDC and USDT via GhoStabilityModule" ;
    rfp:dimension "stablecoin-dependency" .

# Exit window
aave:v3-eth-exitwindow a rfp:ExitWindow ;
    rfp:statedBy feed:defiscan ; rfp:about aave:v3-ethereum ;
    rfp:scoreValue 604800 ;
    rfp:scoreUnit "seconds" ;
    rdfs:label "7 days exit window applies only to GovernanceV3 and AAVE token upgrades (Level 2). Level 1 upgrades have no exit window." .
