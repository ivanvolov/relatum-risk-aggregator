# Stage requirements outcomes (9 atomic findings: 6 fixed, 3 unfixed)
aave:v3-eth-req-s0-1 a rfp:Finding ; rfp:statedBy feed:defiscan ; rfp:about aave:v3-ethereum ;
    rfp:dimension "stage-0-req" ;
    rdfs:label "Assets are not in custody by a centralized entity — fixed" .
