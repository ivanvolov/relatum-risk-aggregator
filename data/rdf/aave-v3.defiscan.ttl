    rfp:dimension "stage-0-req" ;
    rdfs:label "All contracts are verified — fixed" .
aave:v3-eth-req-s0-3 a rfp:Finding ; rfp:statedBy feed:defiscan ; rfp:about aave:v3-ethereum ;
    rfp:dimension "stage-0-req" ;
    rdfs:label "Source-available codebase — fixed" .
aave:v3-eth-req-s0-4 a rfp:Finding ; rfp:statedBy feed:defiscan ; rfp:about aave:v3-ethereum ;
    rfp:dimension "stage-0-req" ;
    rdfs:label "Public documentation exists — fixed" .
