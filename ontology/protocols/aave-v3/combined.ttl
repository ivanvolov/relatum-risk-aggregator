rfp: a owl:Ontology ;
    rdfs:label "Neutral DeFi Risk Intelligence vocabulary" ;
    dcterms:created "2026-06-14"^^xsd:date ;
    dcterms:description "Schema for aggregating risk claims from multiple DeFi risk feeds about the same subject, preserving attribution and avoiding synthesis." .

rfp:about a owl:ObjectProperty ;
    rdfs:domain rfp:Claim ;
    rdfs:range rfp:Subject .

rfp:coverageReason a owl:DatatypeProperty ;
    rdfs:domain rfp:CoverageStatement ;
    rdfs:range xsd:string .

rfp:coverageStatus a owl:DatatypeProperty ;
    rdfs:comment "covered | notCovered | partiallyCovered" ;
    rdfs:domain rfp:CoverageStatement ;
    rdfs:range xsd:string .

rfp:curates a owl:ObjectProperty ;
    rdfs:domain rfp:Curator ;
    rdfs:range rfp:Vault .

rfp:dependsOn a owl:ObjectProperty ;
    rdfs:domain rfp:Subject ;
    rdfs:range rfp:Subject .

rfp:dimension a owl:DatatypeProperty ;
    rdfs:comment "Which risk dimension this claim concerns: e.g. 'upgradeability', 'oracle', 'liquidity'." ;
    rdfs:domain rfp:Claim ;
    rdfs:range xsd:string .

rfp:hasClaim a owl:ObjectProperty ;
    rdfs:domain rfp:Subject ;
    rdfs:range rfp:Claim .

rfp:hasContract a owl:ObjectProperty ;
    rdfs:domain rfp:Protocol ;
    rdfs:range rfp:Contract .

rfp:issues a owl:ObjectProperty ;
    rdfs:domain rfp:Protocol ;
    rdfs:range rfp:Stablecoin .

rfp:methodologyURL a owl:DatatypeProperty ;
    rdfs:range xsd:anyURI .

rfp:observedAt a owl:DatatypeProperty ;
    rdfs:domain rfp:Claim ;
    rdfs:range xsd:dateTime .

rfp:ratingScale a owl:DatatypeProperty ;
    rdfs:comment "Free-text label of the feed's own scale, e.g. 'A+..D' or 'Stage 0..2' or 'L/M/H'." ;
    rdfs:domain rfp:Rating ;
    rdfs:range xsd:string .

rfp:ratingValue a owl:DatatypeProperty ;
    rdfs:comment "Letter or label as published by the feed. NEVER mapped across feeds." ;
    rdfs:domain rfp:Rating ;
    rdfs:range xsd:string .

rfp:scoreUnit a owl:DatatypeProperty ;
    rdfs:domain rfp:Score ;
    rdfs:range xsd:string .

rfp:scoreValue a owl:DatatypeProperty ;
    rdfs:domain rfp:Score ;
    rdfs:range xsd:decimal .

rfp:sourceURL a owl:DatatypeProperty ;
    rdfs:comment "Where on the feed this claim can be re-verified by a human." ;
    rdfs:domain rfp:Claim ;
    rdfs:range xsd:anyURI .

rfp:statedBy a owl:ObjectProperty ;
    rdfs:comment "Provenance: which feed authored this claim. Non-optional." ;
    rdfs:domain rfp:Claim ;
    rdfs:range rfp:Feed .

rfp:Contract a owl:Class ;
    rdfs:comment "Specific deployed smart contract; usually a component of a Protocol." .

rfp:ExitWindow a owl:Class ;
    rdfs:subClassOf rfp:Finding .

rfp:Vault a owl:Class ;
    rdfs:subClassOf rfp:Subject .

feed:stablewatch a rfp:Feed ;
    rdfs:label "Stablewatch" ;
    rfp:methodologyURL "https://www.stablewatch.io"^^xsd:anyURI .

<https://relatum.xyz/ns/protocol/aave/v3-ethereum-cbBTC-USDC> a rfp:Market ;
    rdfs:label "Aave v3 Ethereum cbBTC/USDC" .

rfp:Stablecoin a owl:Class ;
    rdfs:subClassOf rfp:Subject .

feed:curatorwatch a rfp:Feed ;
    rdfs:label "CuratorWatch" ;
    rfp:methodologyURL "https://curatorwatch.com"^^xsd:anyURI .

rfp:Dependency a owl:Class ;
    rdfs:subClassOf rfp:Finding .

rfp:Market a owl:Class ;
    rdfs:comment "A lending market = (Protocol, collateral, debt asset, chain)." ;
    rdfs:subClassOf rfp:Subject .

rfp:Protocol a owl:Class ;
    rdfs:subClassOf rfp:Subject .

rfp:Curator a owl:Class ;
    rdfs:subClassOf rfp:Subject .

rfp:Permission a owl:Class ;
    rdfs:subClassOf rfp:Finding .

<https://relatum.xyz/ns/protocol/aave/v3-ethereum-WETH-USDC> a rfp:Market ;
    rdfs:label "Aave v3 Ethereum WETH/USDC" .

feed:credora a rfp:Feed ;
    rdfs:label "Credora" ;
    rfp:methodologyURL "https://credora.network"^^xsd:anyURI .

rfp:Feed a owl:Class ;
    rdfs:label "Risk Feed" ;
    rdfs:comment "A risk-intelligence source (DeFiScan, Pharos, Credora, …). Identified by stable URI." .

rfp:Subject a owl:Class ;
    rdfs:label "Risk Subject" ;
    rdfs:comment "Anything a feed can make a risk claim about: a Protocol, a Market, a Vault, a Stablecoin, a Curator." .

rfp:Claim a owl:Class ;
    rdfs:label "Risk Claim" ;
    rdfs:comment "A reified statement: this feed says this thing about this subject at this time. All ratings are claims." .

rfp:CoverageStatement a owl:Class ;
    rdfs:comment "Explicit positive or negative coverage. NotCovered is data, not absence." ;
    rdfs:subClassOf rfp:Claim .

feed:defisphere a rfp:Feed ;
    rdfs:label "DeFi Sphere" ;
    rfp:methodologyURL "https://blockanalitica.substack.com/p/introducing-sphere-risk-scores"^^xsd:anyURI .

feed:blockanalitica a rfp:Feed ;
    rdfs:label "Block Analitica" ;
    rfp:methodologyURL "https://blockanalitica.com"^^xsd:anyURI .

feed:defisaver a rfp:Feed ;
    rdfs:label "DeFi Saver" ;
    rfp:methodologyURL "https://help.defisaver.com"^^xsd:anyURI .

rfp:Rating a owl:Class ;
    rdfs:subClassOf rfp:Claim .

<https://relatum.xyz/ns/protocol/aave/v3-ethereum-wstETH-USDC> a rfp:Market ;
    rdfs:label "Aave v3 Ethereum wstETH (collateral) / USDC (debt)",
        "Aave v3 Ethereum wstETH/USDC" .

feed:pharos a rfp:Feed ;
    rdfs:label "Pharos" ;
    rfp:methodologyURL "https://pharos.watch/methodology/"^^xsd:anyURI .

<https://relatum.xyz/ns/protocol/aave/GHO> a rfp:Stablecoin ;
    rdfs:label "GHO" ;
    rfp:dependsOn <https://relatum.xyz/ns/protocol/aave/v3-ethereum> .

feed:defiscan a rfp:Feed ;
    rdfs:label "DeFiScan" ;
    rfp:methodologyURL "https://defiscan.info/framework"^^xsd:anyURI .

rfp:Score a owl:Class ;
    rdfs:subClassOf rfp:Claim .

rfp:Finding a owl:Class ;
    rdfs:comment "Structural finding: a permission, dependency, or exit-window observation." ;
    rdfs:subClassOf rfp:Claim .

<https://relatum.xyz/ns/protocol/aave/v3-ethereum> a rfp:Protocol ;
    rdfs:label "Aave v3 — Ethereum Core" ;
    rfp:issues <https://relatum.xyz/ns/protocol/aave/GHO> .

