    rfp:methodologyURL "https://defipunkd.com"^^xsd:anyURI .
feed:pharos         a rfp:Feed ; rdfs:label "Pharos" ;
    rfp:methodologyURL "https://pharos.watch/methodology/"^^xsd:anyURI .
feed:defisphere     a rfp:Feed ; rdfs:label "DeFi Sphere" ;
    rfp:methodologyURL "https://blockanalitica.substack.com/p/introducing-sphere-risk-scores"^^xsd:anyURI .
feed:defisaver      a rfp:Feed ; rdfs:label "DeFi Saver" ;
    rfp:methodologyURL "https://help.defisaver.com"^^xsd:anyURI .
feed:credora        a rfp:Feed ; rdfs:label "Credora" ;
    rfp:methodologyURL "https://credora.network"^^xsd:anyURI .
feed:risklayer      a rfp:Feed ; rdfs:label "RiskLayer" ;
    rfp:methodologyURL "https://risklayer.io"^^xsd:anyURI .
feed:pigi           a rfp:Feed ; rdfs:label "pigi.finance" ;
    rfp:methodologyURL "https://pigi.finance"^^xsd:anyURI .
feed:xerberus       a rfp:Feed ; rdfs:label "Xerberus" ;
    rfp:methodologyURL "https://xerberus.io"^^xsd:anyURI .
feed:zyfai          a rfp:Feed ; rdfs:label "Zyfai Risk" ;
    rfp:methodologyURL "https://zyf.ai"^^xsd:anyURI .
feed:llamarisk      a rfp:Feed ; rdfs:label "LlamaRisk" ;
    rfp:methodologyURL "https://www.llamarisk.com"^^xsd:anyURI .
feed:philidor       a rfp:Feed ; rdfs:label "Philidor" ;
    rfp:methodologyURL "https://philidor.io"^^xsd:anyURI .
feed:stablewatch    a rfp:Feed ; rdfs:label "Stablewatch" ;
