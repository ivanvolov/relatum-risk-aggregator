@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix rfp:    <https://relatum.xyz/ns/rfp#> .
@prefix feed:   <https://relatum.xyz/ns/feed/> .

# Feed registry — instances of rfp:Feed.
# Schema lives in vocab.ttl; this file is the closed set of feeds the aggregator tracks.

feed:defiscan       a rfp:Feed ; rdfs:label "DeFiScan" ;
    rfp:methodologyURL "https://defiscan.info/framework"^^xsd:anyURI .
feed:blockanalitica a rfp:Feed ; rdfs:label "Block Analitica" ;
    rfp:methodologyURL "https://blockanalitica.com"^^xsd:anyURI .
